    "astro",
    "cloudflare-workers",
    "cms",
    "content",
    "d1",
    "edge",
    "inline-editing",
    "prosekit",
    "solid-js"
  ],
  "homepage": "https://louisetoolkit.com",
  "bugs": "https://github.com/bowenlabs/louise-toolkit/issues",
  "license": "MIT",
  "author": "BowenLabs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bowenlabs/louise-toolkit.git",
    "directory": "packages/louise"
  },
  "bin": {
    "louise": "./bin/louise.mjs"
  },
  "files": [
    "dist",
    "bin",
    "src/theme",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
