{
  "name": "louisecms",
  "version": "0.1.0",
  "description": "Louise CMS — a V8-native, inline edit-on-the-live-page CMS for Cloudflare Workers. Framework-agnostic core primitives (cms, db, commerce, email, queues), a SolidJS + ProseKit inline-edit client, and the daisyUI editor theme.",
  "keywords": [
    "astro",
    "cloudflare-workers",
    "cms",
    "d1",
    "edge",
    "inline-editing",
    "prosekit",
    "solid-js"
  ],
  "homepage": "https://louisecms.com",
  "bugs": "https://github.com/bowenlabs/louisecms/issues",
  "license": "MIT",
  "author": "BowenLabs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bowenlabs/louisecms.git",
    "directory": "packages/louise"
  },
  "bin": {
    "louise": "./bin/louise.mjs"
  },
  "files": [
    "dist",
    "bin",
    "src/theme",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    "./auth": {
      "types": "./dist/core/auth/index.d.ts",
      "import": "./dist/core/auth/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./client/drawer": {
      "types": "./dist/client/drawer/index.d.ts",
      "import": "./dist/client/drawer/index.js"
    },
    "./cms": {
      "types": "./dist/core/cms/index.d.ts",
      "import": "./dist/core/cms/index.js"
    },
    "./db": {
      "types": "./dist/core/db/index.d.ts",
      "import": "./dist/core/db/index.js"
    },
    "./commerce": {
      "types": "./dist/core/commerce/index.d.ts",
      "import": "./dist/core/commerce/index.js"
    },
    "./commerce/fourthwall": {
      "types": "./dist/core/commerce/fourthwall.d.ts",
      "import": "./dist/core/commerce/fourthwall.js"
    },
    "./commerce/stripe": {
      "types": "./dist/core/commerce/stripe.d.ts",
      "import": "./dist/core/commerce/stripe.js"
    },
    "./commerce/square": {
      "types": "./dist/core/commerce/square.d.ts",
      "import": "./dist/core/commerce/square.js"
    },
    "./email": {
      "types": "./dist/core/email/index.d.ts",
      "import": "./dist/core/email/index.js"
    },
    "./media": {
      "types": "./dist/core/media/index.d.ts",
      "import": "./dist/core/media/index.js"
    },
    "./queues": {
      "types": "./dist/core/queues/index.d.ts",
      "import": "./dist/core/queues/index.js"
    },
    "./security": {
      "types": "./dist/core/security/index.d.ts",
      "import": "./dist/core/security/index.js"
    },
    "./errors": {
      "types": "./dist/core/errors.d.ts",
      "import": "./dist/core/errors.js"
    },
    "./theme/louise.css": "./src/theme/louise.css",
    "./theme/fonts.css": "./src/theme/fonts.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "NODE_PATH=node_modules vp pack",
    "pack": "NODE_PATH=node_modules vp pack",
    "dev": "NODE_PATH=node_modules vp pack --watch",
    "check": "vp check",
    "test": "vp test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@better-auth/passkey": "^1.6.23",
    "@cloudflare/workers-types": "^5.20260703.1",
    "@phosphor-icons/core": "^2.1.1",
    "@prosekit/pm": "^0.1.18",
    "@tanstack/solid-query": "^5.101.2",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.0",
    "happy-dom": "^17.0.0",
    "prosekit": "^0.21.4",
    "solid-js": "^1.9.14",
    "typescript": "^5.8.0",
    "ultrahtml": "^1.6.0",
    "vite-plugin-solid": "^2.11.7",
    "vitest": "^3.2.0"
  },
  "peerDependencies": {
    "@better-auth/passkey": "^1.6.23",
    "@prosekit/pm": "^0.1.18",
    "@tanstack/solid-query": "^5.101.2",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.0",
    "prosekit": "^0.21.4",
    "solid-js": "^1.9.14"
  },
  "peerDependenciesMeta": {
    "@better-auth/passkey": {
      "optional": true
    },
    "@prosekit/pm": {
      "optional": true
    },
    "@tanstack/solid-query": {
      "optional": true
    },
    "better-auth": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    },
    "prosekit": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    }
  }
}
