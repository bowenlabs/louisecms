---
// Boots the in-page Louise editor — the edit bar + the Settings drawer (Pages,
// Media, Settings, Users). Drop it before </body> in your layout.
//
// Gated on `Astro.locals.editMode`, which the generated middleware sets for a
// signed-in editor who has toggled edit mode on (`?louise`). An anonymous visitor
// gets editMode=false, so the heavy Solid/ProseKit client is never even sent to
// them. The client self-injects its own styles.
//
// Pass `versionedPageId` from a page whose `<Editable>` fields should stage drafts
// + publish (the layout forwards it). Omit it and the bar is Settings-only.
const { editMode, editor } = Astro.locals;
const { versionedPageId, sections } = Astro.props as {
  versionedPageId?: number;
  sections?: unknown;
};

// The section editor needs the page's CURRENT sections array to seed its store.
// It rides as JSON on the boot marker for the same reason the other values do:
// a `define:vars` script would be `is:inline` with per-request content, which
// can't be hashed into `script-src` and so would be CSP-blocked.
const sectionsJson = Array.isArray(sections) ? JSON.stringify(sections) : undefined;
---

{
  editMode && (
    <>
      {/* Per-render values (editor name, versioned page id) ride as data-* on this
          marker element rather than a define:vars inline script. define:vars forces
          is:inline, whose content varies per request and so can't be hashed by
          Astro's security.csp — it would be CSP-blocked. The boot script below
          reads them from here; being static, it hashes cleanly into script-src.
          The element also gates the editor: no marker (a non-edit page swapped in
          by a view transition) → boot() no-ops. */}
      <div
        id="louise-boot"
        hidden
        data-louise-user={editor?.name ?? "Editor"}
        data-louise-versioned-page={versionedPageId != null ? String(versionedPageId) : undefined}
        data-louise-sections={sectionsJson}
      />
      <script>
        // Lazy-import the editor client only in edit mode. `mountLouise` renders
        // the edit bar; `mountSettings` renders the drawer (Pages/Media/Settings +
        // Users, backed by editorsRoute). When the page passes `versionedPageId`,
        // the bar gains Save draft + Publish, and this page's `<Editable>` fields
        // are edited in place — their changes stage a draft, promoted on Publish.
        function boot() {
          const el = document.getElementById("louise-boot");
          if (!el) return;
          Promise.all([
            import("louise-toolkit/client"),
            import("louise-toolkit/client/settings"),
            import("astroidjs/components/sections"),
          ])
            .then(([client, settings, lib]) => {
              settings.mountSettings({
                userName: el.dataset.louiseUser || "Editor",
                users: true,
              });
              const versioned = el.dataset.louiseVersionedPage;
              const pageId = versioned ? Number(versioned) : undefined;
              client.mountLouise({
                onOpenSettings: () =>
                  window.dispatchEvent(new Event(settings.OPEN_SETTINGS_EVENT)),
                versionedPageId: pageId,
              });

              // The on-canvas section editor. It edits the SAME catalog the
              // server validates writes against (astroidSectionCatalog), so a
              // field can't be editable-but-invalid.
              //
              // Mounted only when this page actually rendered sections: the host
              // is emitted by <Sections>, and the array rides on the boot marker.
              // A page with neither (the login page, a bespoke route) skips it.
              const host = document.querySelector<HTMLElement>("[data-louise-sections-host]");
              const raw = el.dataset.louiseSections;
              if (host && raw && pageId != null) {
                client.mountSections(host, {
                  catalog: lib.astroidSectionCatalog,
                  pageId,
                  initial: JSON.parse(raw),
                });
              }
            })
            .catch((err) => console.error("[louise] editor bootstrap failed", err));
        }
        boot();
        // Re-boot after a view-transition navigation (the swapped-in body needs it).
        document.addEventListener("astro:page-load", boot);
      </script>
    </>
  )
}
