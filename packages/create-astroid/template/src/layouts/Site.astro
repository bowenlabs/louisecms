---
// The base HTML shell. `Astro.locals.editMode` is set by the generated
// middleware.ts (from your auth seam); LouiseEdit boots the editor when it's on.
//
// SEO is settings-driven: the `site_settings` row supplies the site-wide title,
// description, and OG image, and a page overrides any of them via props.
// <StructuredData> emits the schema.org graph (business + WebSite), with the
// business `@type` chosen from your archetype.
import Seo from "astroidjs/components/Seo.astro";
import StructuredData from "astroidjs/components/StructuredData.astro";
import { env } from "cloudflare:workers";
import astroidConfig from "../../astroid.config.js";
import LouiseEdit from "../components/LouiseEdit.astro";
import "../styles/site.css";

interface Props {
  title?: string;
  description?: string;
  /** Absolute or root-relative share image; falls back to the site default. */
  ogImage?: string;
  /** Keep this page out of search indexes (cart, checkout, account). */
  noindex?: boolean;
  /** A `pages` row id whose `<Editable>` fields stage drafts + publish. */
  versionedPageId?: number;
  /** The page's stored `sections` array, forwarded to the on-canvas section
   *  editor so it can seed its store with what's actually rendered. */
  sections?: unknown;
}

const { title, description, ogImage, noindex, versionedPageId, sections } = Astro.props;
const { editMode } = Astro.locals;

// The editable settings row drives the head. Missing (pre-provision, pre-seed)
// falls back to the brand name from your config, so a fresh clone still renders
// a sane <title> rather than an empty one.
type Settings = {
  site_name: string | null;
  tagline: string | null;
  meta_description: string | null;
  default_og_image_url: string | null;
  logo_url: string | null;
  contact_email: string | null;
  contact_phone: string | null;
  contact_address: string | null;
  social_links: string | null;
  disable_indexing: number | null;
};
let row: Settings | null = null;
try {
  row = await env.DB.prepare(
    `SELECT site_name, tagline, meta_description, default_og_image_url, logo_url,
            contact_email, contact_phone, contact_address, social_links, disable_indexing
     FROM site_settings WHERE id = 1`,
  ).first<Settings>();
} catch {
  // No DB binding yet — fall through to the config defaults below.
}

const settings = {
  siteName: row?.site_name ?? astroidConfig.theme.name,
  tagline: row?.tagline,
  metaDescription: row?.meta_description,
  defaultOgImageUrl: row?.default_og_image_url,
  logoUrl: row?.logo_url,
  contactEmail: row?.contact_email,
  contactPhone: row?.contact_phone,
  contactAddress: row?.contact_address,
  // Stored as a JSON string; a malformed value must not take down the page.
  socialLinks: (() => {
    try {
      return row?.social_links ? JSON.parse(row.social_links) : undefined;
    } catch {
      return undefined;
    }
  })(),
  disableIndexing: Boolean(row?.disable_indexing),
};
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Seo
      settings={settings}
      title={title}
      description={description}
      ogImage={ogImage}
      noindex={noindex}
      titleTemplate={astroidConfig.seo?.titleTemplate}
      twitterHandle={astroidConfig.seo?.twitterHandle}
      locale={astroidConfig.seo?.locale}
    />
    <StructuredData config={astroidConfig} settings={settings} />
  </head>
  <body class="min-h-screen bg-base-100 text-base-content" data-edit-mode={editMode ? "" : undefined}>
    <slot />
    <LouiseEdit versionedPageId={versionedPageId} sections={sections} />
  </body>
</html>
