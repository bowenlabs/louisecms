# Local dev secrets (wrangler reads .dev.vars; copy this there for `astro dev`).
# In production these are set with `wrangler secret put`, NOT committed.
#
# Astroid's convention: an unprovisioned secret leaves its feature DORMANT, never
# broken. A secret that is empty — or still holds the DUMMY_REPLACE_ME sentinel —
# reads as "not configured", so a fresh clone boots and runs with no external
# accounts at all. Replace a value to switch that feature on.

# Signs Better Auth sessions. Generate: `openssl rand -base64 32`.
# Empty is fine on localhost (a fixed dev secret keeps sign-in working); any
# deployed host fails closed rather than signing sessions with a known value.
SESSION_SECRET=

# The first editor's email — seeded as an admin `user` row by `pnpm seed:editors`,
# and thereafter part of the DB-managed magic-link allowlist.
OWNER_EMAIL=you@example.com

# `from` address for magic-link + notification email (Cloudflare Email Sending).
MAIL_FROM=no-reply@__KEY__.example

# Turnstile captcha on the magic-link endpoint. Dormant as shipped: the sentinel
# secret below plus Cloudflare's always-passing TEST site key. Captcha only
# enforces once BOTH are real — provisioning one half can't lock you out of your
# own sign-in. Get a real pair at dash.cloudflare.com → Turnstile.
TURNSTILE_SECRET=DUMMY_REPLACE_ME
TURNSTILE_SITE_KEY=1x00000000000000000000AA
