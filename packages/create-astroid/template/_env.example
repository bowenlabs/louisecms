# Local dev secrets (wrangler reads .dev.vars; copy this there for `astro dev`).
# In production these are set with `wrangler secret put`, NOT committed.
#
# Astroid's convention: an unprovisioned secret leaves its feature DORMANT, never
# broken. A secret that is empty — or still holds the DUMMY_REPLACE_ME sentinel —
# reads as "not configured", so a fresh clone boots and runs with no external
# accounts at all. Replace a value to switch that feature on.

# Signs Better Auth sessions. Generate: `openssl rand -base64 32`.
#
# Empty is fine under `pnpm dev` — astro dev serves on localhost, where a fixed
# dev secret keeps the sign-in → session loop working. Any deployed host fails
# closed rather than signing sessions with a known value.
#
# BUT a local `wrangler dev` preview of the BUILT worker is not localhost as far
# as the app is concerned: wrangler routes the request through your `hosts`
# domain (astroid.config.ts), so the dev fallback never fires and every editor
# route 500s with "SESSION_SECRET is not configured". Set a value here before
# previewing the built worker that way.
SESSION_SECRET=

# The first editor's email — seeded as an admin `user` row by `pnpm seed:editors`,
# and thereafter part of the DB-managed magic-link allowlist.
OWNER_EMAIL=you@example.com

# `from` address for magic-link + notification email (Cloudflare Email Sending).
MAIL_FROM=no-reply@__KEY__.example

# Turnstile captcha on the magic-link endpoint. Dormant as shipped: the sentinel
# secret below plus Cloudflare's always-passing TEST site key. Captcha only
# enforces once BOTH are real — provisioning one half can't lock you out of your
# own sign-in. Get a real pair at dash.cloudflare.com → Turnstile.
TURNSTILE_SECRET=DUMMY_REPLACE_ME
TURNSTILE_SITE_KEY=1x00000000000000000000AA
__ASTROID_MODULE_SECRETS__

# --- web vitals -----------------------------------------------------------
#
# ONLY needed to read Core Web Vitals back out. Collection works without them:
# the beacon posts to /api/louise/vitals and the Worker writes to the Analytics
# Engine dataset regardless. Querying the p75 back out goes through the SQL API,
# which is account-scoped and has no binding — hence a token.
#
# Left as the sentinel, the daily health scan simply skips the query and the
# Health panel shows "not measured yet". Create a token with Account
# Analytics:Read at dash.cloudflare.com → My Profile → API Tokens.
CF_ACCOUNT_ID=DUMMY_REPLACE_ME
CF_API_TOKEN=DUMMY_REPLACE_ME
