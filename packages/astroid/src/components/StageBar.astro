---
// `<StageBar>` — a pipeline's progress as a segmented bar.
//
// Generalized from ghostfire's six-stage floor tracker, which hard-coded the
// segment count, the corner radii, the brand hex codes, and a mascot image.
// Here the stage list drives everything and the colours are theme tokens, so a
// four-stage onboarding flow and an eight-stage production line both work and
// a re-theme needs no edit.
//
// Rendered as an ordered list rather than a row of divs: the stages ARE a
// sequence, `aria-current` says which one is live, and a screen reader gets
// "step 3 of 6, Dried, current" instead of silence.
interface Props {
  /** Stage labels, in order. */
  stages: readonly string[];
  /** Stage currently in progress. `>= stages.length` renders everything done. */
  stage: number;
  /**
   * An optional marker (an emoji, a mascot glyph) that rides above the active
   * segment. Off by default — the reference's bobbing ghost is brand, not
   * mechanism.
   */
  marker?: string;
  class?: string;
}

const { stages, stage, marker, class: className } = Astro.props;

// Clamp rather than trust: `stage` comes from a database column, and a value
// past the end is the normal "complete" state rather than an error.
const current = Math.max(0, Math.min(stage, stages.length));
const complete = current >= stages.length;

// Percent across the bar, centred on the active segment. Only computed when
// there is an active segment to point at.
const markerLeft = complete ? null : `${(((current + 0.5) / stages.length) * 100).toFixed(2)}%`;
---

<div class:list={["astroid-stagebar", className]}>
  {marker && markerLeft && (
    <span aria-hidden="true" class="astroid-stagebar__marker" style={`left:${markerLeft}`}>
      {marker}
    </span>
  )}
  <ol class="astroid-stagebar__track">
    {stages.map((label, i) => (
      <li
        class="astroid-stagebar__step"
        data-state={i < current ? "done" : i === current ? "current" : "upcoming"}
        aria-current={i === current ? "step" : undefined}
      >
        <span class="astroid-stagebar__seg" />
        <span class="astroid-stagebar__label">{label}</span>
      </li>
    ))}
  </ol>
</div>

<style>
  .astroid-stagebar {
    position: relative;
  }
  .astroid-stagebar__track {
    display: flex;
    gap: 0.25rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .astroid-stagebar__step {
    display: flex;
    min-width: 0;
    flex: 1 1 0;
    flex-direction: column;
    gap: 0.5rem;
  }
  .astroid-stagebar__seg {
    height: 1.75rem;
    border-radius: 0.25rem;
    background: var(--fallback-b3, oklch(var(--b3)));
    transition: background-color 300ms ease;
  }
  /* Round only the outer ends, so the bar reads as one track rather than a row
     of separate pills — at any segment count. */
  .astroid-stagebar__step:first-child .astroid-stagebar__seg {
    border-start-start-radius: 999px;
    border-end-start-radius: 999px;
  }
  .astroid-stagebar__step:last-child .astroid-stagebar__seg {
    border-start-end-radius: 999px;
    border-end-end-radius: 999px;
  }
  .astroid-stagebar__step[data-state="done"] .astroid-stagebar__seg {
    background: var(--fallback-p, oklch(var(--p)));
  }
  .astroid-stagebar__step[data-state="current"] .astroid-stagebar__seg {
    background: var(--fallback-a, oklch(var(--a)));
    animation: astroid-stagebar-pulse 1.6s ease-in-out infinite;
  }
  .astroid-stagebar__label {
    text-align: center;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    opacity: 0.45;
  }
  .astroid-stagebar__step[data-state="done"] .astroid-stagebar__label,
  .astroid-stagebar__step[data-state="current"] .astroid-stagebar__label {
    opacity: 1;
  }
  .astroid-stagebar__marker {
    position: absolute;
    top: -1.9rem;
    z-index: 1;
    translate: -50%;
    font-size: 1.5rem;
    line-height: 1;
    transition: left 500ms ease;
  }

  @keyframes astroid-stagebar-pulse {
    50% {
      opacity: 0.6;
    }
  }
  /* The pulse is decoration on top of a state that colour and `aria-current`
     already convey, so it costs nothing to drop. */
  @media (prefers-reduced-motion: reduce) {
    .astroid-stagebar__step[data-state="current"] .astroid-stagebar__seg {
      animation: none;
    }
    .astroid-stagebar__marker {
      transition: none;
    }
  }
</style>
