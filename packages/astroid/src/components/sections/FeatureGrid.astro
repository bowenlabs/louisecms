---
// Feature-grid section (ADR 0003, item 4) — value-prop cards. Declarative
// props → `Theme` tokens via `colorwayClass`.
import type { FeatureGridFields, SectionBase } from "../sections.js";
import { colorwayClass } from "../sections.js";

type Props = SectionBase & FeatureGridFields;

const { heading, items, colorway = "base" } = Astro.props;
---

<section class:list={["py-16", colorwayClass(colorway)]}>
  <div class="mx-auto max-w-5xl px-6">
    {heading && <h2 class="mb-8 text-3xl font-bold">{heading}</h2>}
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {items.map((item) => (
        <div class="card bg-base-100 text-base-content shadow-sm">
          <div class="card-body">
            <h3 class="card-title">{item.title}</h3>
            <p class="opacity-80">{item.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
