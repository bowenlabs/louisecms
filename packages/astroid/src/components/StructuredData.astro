---
// `<StructuredData>` — the schema.org JSON-LD `@graph` for rich results and AI
// answer surfaces: the business (its `@type` from the archetype), the WebSite,
// and optionally the entity this page is about.
//
// `is:inline` is required, not stylistic. Astro would otherwise treat the block
// as a script to process and hash; `application/ld+json` is a data block the
// browser never executes, so `script-src` doesn't govern it and it needs no
// hash. See `escapeJsonLd` for why the payload is escaped rather than stringified.
import { astroidStructuredData, escapeJsonLd } from "astroidjs";
import type { AstroidConfig, JsonLdNode, StructuredDataInput } from "astroidjs";

interface Props {
  config: AstroidConfig;
  settings: StructuredDataInput["settings"];
  /** Absolute origin serving this page. Defaults to the current origin, which
   *  keeps a preview deploy describing itself rather than the live domain. */
  siteUrl?: string;
  /** The thing this page is about — a Product, VisualArtwork, Article. */
  entity?: JsonLdNode;
}

const { config, settings, siteUrl, entity } = Astro.props;

const graph = astroidStructuredData({
  config,
  settings,
  siteUrl: siteUrl ?? Astro.url.origin,
  entity,
});
---

<script type="application/ld+json" is:inline set:html={escapeJsonLd(graph)} />
