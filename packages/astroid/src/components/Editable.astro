---
// `<Editable>` — the Astroid inline-edit primitive (ADR 0003, checklist item 1).
//
// It owns the `data-louise-*` marker contract so sites stop stamping it by hand:
// in edit mode it renders your element with the markers the Louise client
// (`mountLouise` / `mountSections`) looks for to make the field editable in place;
// out of edit mode it renders the element plain, with zero editing attributes in
// the public HTML.
//
// Two flavors, per which surface the field lives on:
//   • PAGE field  — pass `collection` + `key` + `field`; emits
//                   `data-louise-field="<collection>:<key>:<field>"` (saved as a
//                   versioned draft when the page is mounted with `versionedPageId`).
//   • SECTION field — pass `base` (this item's path, e.g. `"2"` or `"2.blocks.0"`)
//                   plus `field`; emits `data-louise-sfield="<base>.<field>"`
//                   (+ `data-louise-multiline`) for the on-canvas section editor.
//                   `sfield` stays as the escape hatch for a path you build
//                   yourself — an array entry: sfield={`${base}.items.${i}.title`}.
//
// The `base` form is what ADR 0005 §2 asks for: "a site author writes `<Editable
// field="heading">` and never hand-stamps the deeper path". `<Section>` supplies
// `base`, so the SAME component renders correctly whether it sits at the top level
// (`"2.heading"`) or inside a block (`"2.blocks.0.heading"`) — the depth never
// appears in the component's source, which is what makes a section component
// reusable as a block component.
//
// Polymorphic via `as` (default `div`) with a typed `...rest` over the div's
// attributes; edit mode is read from context (`Astro.locals.editMode`) unless the
// caller passes `edit` (a section knows its own edit flag).
import type { HTMLAttributes, HTMLTag } from "astro/types";

interface Props extends HTMLAttributes<"div"> {
  /** The element to render. Default `"div"`. */
  as?: HTMLTag;
  /** PAGE-field mode: the Louise collection slug (e.g. `"pages"`). */
  collection?: string;
  /** PAGE-field mode: the row key/id the field is on. */
  key?: string | number;
  /** PAGE-field mode: the field name (e.g. `"title"`, `"body"`). Also the field
   *  name in SECTION mode, where it's joined onto `base`. */
  field?: string;
  /** SECTION-field mode: this item's path prefix (`"2"`, `"2.blocks.0"`),
   *  supplied by `<Section>`. Combined with `field` to build the marker. */
  base?: string;
  /** SECTION-field mode, explicit: the full `<index>.<path>` marker. Overrides
   *  `base`+`field`, for paths a component builds itself (array entries). */
  sfield?: string;
  /** Rich text (ProseKit) vs a single-line contenteditable. Default `"text"`. */
  type?: "text" | "richtext";
  /** SECTION-field mode: allow newlines in a plain-text field. */
  multiline?: boolean;
  /** Force edit markers on/off. Defaults to `Astro.locals.editMode`. */
  edit?: boolean;
}

const {
  as: Tag = "div",
  collection,
  key,
  field,
  base,
  sfield,
  type = "text",
  multiline = false,
  edit,
  ...rest
} = Astro.props;

// An explicit `sfield` wins; otherwise `base` + `field` compose one. Both absent
// means this isn't a section field at all, and the page-field branch below runs.
const sectionPath = sfield ?? (base !== undefined && field ? `${base}.${field}` : undefined);

const editing = edit ?? (Astro.locals as { editMode?: boolean }).editMode ?? false;
// Annotated rather than inferred: without it the ternary widens to a union of
// two object shapes, one of which carries `"data-louise-type"?: undefined`, and
// spreading that into `Record<string, string>` is a type error.
const richText: Record<string, string> =
  type === "richtext" ? { "data-louise-type": "richtext" } : {};
const multilineMarker: Record<string, string> = multiline ? { "data-louise-multiline": "" } : {};

let markers: Record<string, string> = {};
if (editing) {
  if (sectionPath) {
    markers = {
      "data-louise-sfield": sectionPath,
      ...richText,
      ...multilineMarker,
    };
  } else if (collection && key !== undefined && field) {
    markers = { "data-louise-field": `${collection}:${key}:${field}`, ...richText };
  }
}
---

<Tag {...rest} {...markers}><slot /></Tag>
