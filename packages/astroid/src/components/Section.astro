---
// `<Section>` — the section-library dispatcher (ADR 0003 item 2, on the ADR 0005
// model).
//
// It renders ONE stored `SectionItem`: dispatch on `_type`, hand the component
// its `base` path, and let the component own every pixel. What changed from the
// old `kind`-prop version is where the truth lives — the item is data loaded from
// the page's `sections` column, not props a template hand-wrote, so what renders
// is exactly what the on-canvas editor edits in place.
//
// Two marker responsibilities, split the way ADR 0005 §2 splits them:
//   • the BOUNDARY (`data-louise-section` / `data-louise-block`) is stamped here,
//     because only the dispatcher knows an item's position;
//   • the FIELDS (`data-louise-sfield`) are stamped by `<Editable base={base}
//     field="…">` inside each component, because only the component knows which
//     of its text nodes are editable.
//
// Blocks recurse through this same component with a deeper `base`. That's the
// whole trick: a component never learns its own depth, so a type that renders as
// a section renders unchanged as a block.
import type { MediaMeta, SectionItem, SectionRenderProps } from "./sections.js";
import AboutIntro from "./sections/AboutIntro.astro";
import Banner from "./sections/Banner.astro";
import Contact from "./sections/Contact.astro";
import Cta from "./sections/Cta.astro";
import Faq from "./sections/Faq.astro";
import FeatureGrid from "./sections/FeatureGrid.astro";
import Gallery from "./sections/Gallery.astro";
import Hero from "./sections/Hero.astro";
import LocationHours from "./sections/LocationHours.astro";
import Media from "./sections/Media.astro";
import PricingTiers from "./sections/PricingTiers.astro";
import ProductGrid from "./sections/ProductGrid.astro";
import SplitImage from "./sections/SplitImage.astro";
import Steps from "./sections/Steps.astro";
import Testimonial from "./sections/Testimonial.astro";

interface Props {
  item: SectionItem;
  /** This item's path within the page's `sections` array: `"2"` at the top
   *  level, `"2.blocks.0"` for a block. */
  base: string;
  /** Force edit markers on/off. Defaults to `Astro.locals.editMode`. */
  edit?: boolean;
  /** Page-wide media alt/caption, resolved once by `<Sections>`. */
  mediaMeta?: MediaMeta;
}

/**
 * `_type` → render component. A map rather than a chain of `{type === "x" && …}`
 * for one reason that matters: it can be checked. A catalog entry whose type is
 * missing here renders NOTHING — a silent hole in the page rather than an error
 * — so the test suite asserts these keys and the catalog's are the same set.
 */
const COMPONENTS: Record<string, ((props: SectionRenderProps) => unknown) | undefined> = {
  hero: Hero,
  featureGrid: FeatureGrid,
  cta: Cta,
  contact: Contact,
  gallery: Gallery,
  media: Media,
  splitImage: SplitImage,
  steps: Steps,
  banner: Banner,
  faq: Faq,
  pricingTiers: PricingTiers,
  testimonial: Testimonial,
  aboutIntro: AboutIntro,
  productGrid: ProductGrid,
  locationHours: LocationHours,
};

const { item, base, edit, mediaMeta } = Astro.props;

const editing = edit ?? (Astro.locals as { editMode?: boolean }).editMode ?? false;
const type = String(item._type);

// `blocks` is the reserved structural key; its marker path is positional
// (`<i>.blocks.<j>`), which is what the client's depth-agnostic path parser walks.
const blocks = Array.isArray(item.blocks) ? item.blocks : [];

// The boundary marker the on-canvas chrome draws its ring on. `class="contents"`
// keeps this wrapper out of layout entirely — the ring is drawn as a box-shadow
// on the element itself (ADR 0005 §3), so an extra block box here would offset
// every section's spacing for the sake of an attribute.
const boundary = editing
  ? base.includes(".blocks.")
    ? { "data-louise-block": base }
    : { "data-louise-section": base }
  : {};

const shared = { item, base, edit: editing, mediaMeta };

// Resolved in the frontmatter so the template is one dynamic tag rather than a
// ladder of comparisons. The map itself is the dispatch check — an unknown
// `_type` (legitimate mid-migration, and already rejected on write) simply
// finds nothing and renders nothing, which is why the lookup is typed as
// possibly-undefined rather than asserted.
const Component = COMPONENTS[type];
---

{
  Component && (
    <div {...boundary} class="contents">
      <Component {...shared} />

      {blocks.map((block, j) => (
        <Astro.self item={block} base={`${base}.blocks.${j}`} edit={editing} mediaMeta={mediaMeta} />
      ))}
    </div>
  )
}
