---
// `<Seo>` — the settings-driven `<head>` block: title (templated), description,
// canonical, robots, Open Graph, and the Twitter/X card.
//
// Tags are emitted directly rather than through a wrapper library. There are
// about fifteen of them, the shapes are frozen by the OG and Twitter specs, and
// owning them means the resolution rules (see `resolvePageSeo`) are the ONLY
// place a value can come from — which is what makes the layer predictable.
//
// JSON-LD is not here: it's a separate concern with different escaping rules and
// its own component (`<StructuredData>`).
import { resolvePageSeo } from "astroidjs";
import type { AstroidSeoSettings, PageSeoInput } from "astroidjs";

interface Props extends PageSeoInput {
  /** The `site_settings` row (or the SEO-relevant subset of it). */
  settings: AstroidSeoSettings;
  /** Absolute canonical URL. Defaults to the URL being rendered. */
  canonical?: string;
  /** Overrides the config's `seo.titleTemplate` for this page. */
  titleTemplate?: string;
  twitterHandle?: string;
  locale?: string;
}

const { settings, canonical, titleTemplate, twitterHandle, locale, ...page } = Astro.props;

const seo = resolvePageSeo(settings, page, {
  canonical: canonical ?? Astro.url.href,
  titleTemplate,
  twitterHandle,
  locale,
});
---

<title>{seo.title}</title>
<link rel="canonical" href={seo.canonical} />
{seo.description && <meta name="description" content={seo.description} />}
{/* nofollow alongside noindex: a page worth hiding is rarely worth crawling. */}
{seo.noindex && <meta name="robots" content="noindex, nofollow" />}

<meta property="og:type" content={seo.ogType} />
{/* The bare title, not the templated one — og:site_name already carries the brand. */}
<meta property="og:title" content={seo.bareTitle} />
<meta property="og:url" content={seo.canonical} />
{seo.description && <meta property="og:description" content={seo.description} />}
{seo.siteName && <meta property="og:site_name" content={seo.siteName} />}
{seo.locale && <meta property="og:locale" content={seo.locale} />}
{seo.ogImage && <meta property="og:image" content={seo.ogImage} />}
{seo.ogImageAlt && <meta property="og:image:alt" content={seo.ogImageAlt} />}

<meta name="twitter:card" content={seo.ogImage ? "summary_large_image" : "summary"} />
<meta name="twitter:title" content={seo.bareTitle} />
{seo.description && <meta name="twitter:description" content={seo.description} />}
{seo.ogImage && <meta name="twitter:image" content={seo.ogImage} />}
{seo.twitterHandle && <meta name="twitter:site" content={seo.twitterHandle} />}
{seo.twitterHandle && <meta name="twitter:creator" content={seo.twitterHandle} />}
