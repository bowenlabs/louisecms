{
  "name": "astroidjs",
  "version": "0.0.0",
  "description": "Astroid — an opinionated meta-framework over Louise Toolkit and Astro for building editable, multi-brand sites on Cloudflare Workers.",
  "keywords": [
    "astro",
    "cloudflare-workers",
    "cms",
    "commerce",
    "louise-toolkit",
    "meta-framework"
  ],
  "license": "MIT",
  "author": "BowenLabs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bowenlabs/louise-toolkit.git",
    "directory": "packages/astroid"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "louise-toolkit": "workspace:*"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
