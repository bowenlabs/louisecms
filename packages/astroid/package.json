{
  "name": "astroidjs",
  "version": "0.1.0",
  "description": "Astroid — an opinionated meta-framework over Louise Toolkit and Astro for building editable, multi-editor sites on Cloudflare Workers.",
  "keywords": [
    "astro",
    "cloudflare-workers",
    "cms",
    "commerce",
    "louise-toolkit",
    "meta-framework"
  ],
  "license": "MIT",
  "author": "BowenLabs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bowenlabs/louise-toolkit.git",
    "directory": "packages/astroid"
  },
  "type": "module",
  "bin": {
    "astroid": "./bin/astroid.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./components/*.astro": "./src/components/*.astro",
    "./components/Collection": {
      "types": "./src/components/Collection.tsx",
      "default": "./src/components/Collection.tsx"
    },
    "./components/sections": {
      "types": "./src/components/sections.ts",
      "default": "./src/components/sections.ts"
    }
  },
  "files": [
    "dist",
    "bin",
    "src/components"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "louise-toolkit": "workspace:*"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "peerDependenciesMeta": {
    "solid-js": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "prepublishOnly": "tsgo -p tsconfig.build.json",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "solid-js": "^1.9.14",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
