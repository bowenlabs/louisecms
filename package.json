{
  "name": "louise-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Louise Toolkit — a V8-native toolkit for building editable sites on Cloudflare Workers. Monorepo: the louise library plus the louisetoolkit.com marketing site and Starlight docs.",
  "license": "MIT",
  "author": "BowenLabs",
  "type": "module",
  "scripts": {
    "build": "sh ./scripts/ci-build.sh",
    "typecheck": "vp run louise#typecheck",
    "check": "vp run louise#check",
    "lint:astro": "biome lint .",
    "lint:astro:fix": "biome lint --write .",
    "lint:solid": "npx --yes -p oxlint@1.73.0 -p eslint-plugin-solid@0.14.5 oxlint packages/louise/src/client",
    "test": "vp run louise#test",
    "dev": "vp run site#dev",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@changesets/cli": "^2.31.0",
    "eslint-plugin-solid": "^0.14.5"
  },
  "engines": {
    "node": ">=26.0.0"
  },
  "packageManager": "pnpm@11.13.0"
}
