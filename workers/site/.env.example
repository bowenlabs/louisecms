# Local dev editor-gate config for `astro dev` — astro:env reads these from .env
# (copy to .env). In production these come from wrangler instead: OWNER_EMAIL from
# `vars` in wrangler.jsonc, and `wrangler secret put NAME` for the secret ones.
# (MEDIA_URL is a Worker `var`, not astro:env — see wrangler.jsonc.)
OWNER_EMAIL=editor@louisetoolkit.com
# Editor gate. Set a real value to sign in at /louise locally; left blank,
# anonymous browsing still works (the sign/verify paths just aren't exercised).
LOUISE_SESSION_SECRET=
LOUISE_EDITOR_PASSWORD=
