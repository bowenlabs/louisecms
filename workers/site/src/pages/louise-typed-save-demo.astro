---
// ADR 0001 proving slice — renders the typed-save island. In the real editor the
// `page` prop comes from the row being edited; here it's sample scaffolding so
// the slice builds and typechecks without a DB read. Not linked from the site.
import type { PageEditInput } from "../lib/louise/page-schema";
import SavePageFields from "../islands/SavePageFields.tsx";

export const prerender = false;

const page: PageEditInput = {
  id: 1,
  title: "Home",
  seoTitle: "",
  seoDescription: "",
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Typed save demo — ADR 0001</title>
    <meta name="robots" content="noindex" />
  </head>
  <body>
    <main>
      <h1>Typed save demo</h1>
      <p>Zod schema → typed Action → typed Solid island, inferred end-to-end.</p>
      <SavePageFields client:load page={page} />
    </main>
  </body>
</html>
