---
// louisecms.com landing page.
// Public site theme: Tailwind v4 + daisyUI, with the `louise` theme defined in
// src/styles/louise.css (auto light/dark via prefers-color-scheme). Brand type
// comes from the package (`louisecms/theme/fonts.css`, applied via `.louise-type`)
// and the hero mark is the real `louise-mark.svg`. Icons are Phosphor, inlined
// raw so they inherit `currentColor` — no icon font, no runtime fetch.
import "louisecms/theme/fonts.css";
import "../styles/louise.css";
import louiseMark from "../assets/louise-mark.svg?raw";
import bookOpen from "@phosphor-icons/core/assets/regular/book-open-text.svg?raw";
import githubLogo from "@phosphor-icons/core/assets/regular/github-logo.svg?raw";
import pencil from "@phosphor-icons/core/assets/regular/pencil-simple.svg?raw";
import textAa from "@phosphor-icons/core/assets/regular/text-aa.svg?raw";
import lightning from "@phosphor-icons/core/assets/regular/lightning.svg?raw";
import plugs from "@phosphor-icons/core/assets/regular/plugs-connected.svg?raw";
import pkg from "@phosphor-icons/core/assets/regular/package.svg?raw";
import cart from "@phosphor-icons/core/assets/regular/shopping-cart-simple.svg?raw";
import shield from "@phosphor-icons/core/assets/regular/shield-check.svg?raw";
import LouiseEditor from "../components/LouiseEditor.astro";
// SSR (not prerendered): the marketing app is `output: server` for Louise, and a
// prerendered `/index.html` asset would shadow the docs root on
// docs.louisecms.com (both map to `/`). Rendering per-request keeps the docs
// subdomain's `/` free for the Worker's /_docs dispatch (see worker.ts).
export const prerender = false;

const year = new Date().getFullYear();
const features = [
  {
    icon: pencil,
    title: "Edit in place",
    body: "Editable regions carry a data-louise-field marker; in edit mode the client makes each one editable right where it lives.",
  },
  {
    icon: textAa,
    title: "Real rich text",
    body: "A ProseKit editor for prose — not a JSON form. Storage is sanitized HTML, rendered straight back onto the page.",
  },
  {
    icon: lightning,
    title: "V8-native",
    body: "No Node runtime, no React. Everything runs in workerd and deploys to Cloudflare Workers at the edge.",
  },
  {
    icon: plugs,
    title: "Bring your own bindings",
    body: "D1, R2, Queues, Email are passed in — Louise never imports cloudflare:workers itself, and has no opinion about your schema or framework.",
  },
  {
    icon: pkg,
    title: "Tree-shakeable",
    body: "One ESM package with granular subpath exports — import only the primitive a route needs.",
  },
  {
    icon: cart,
    title: "Commerce included",
    body: "Stripe, Square, and Fourthwall clients — raw fetch + crypto.subtle over a shared signature/money base. No SDKs.",
  },
  {
    icon: shield,
    title: "Auth & security",
    body: "Opt-in magic-link + passkey studio sign-in (Better Auth), a rich-text sanitizer, and a KV rate limiter — one fix protects every site.",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Louise CMS — edit the live page</title>
    <meta
      name="description"
      content="A V8-native, inline edit-on-the-live-page CMS for Cloudflare Workers."
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body class="louise-type min-h-screen bg-base-100 text-base-content antialiased">
    <main class="mx-auto max-w-4xl px-5">
      <section class="pt-24 pb-12 text-center">
        <div
          class="mx-auto mb-6 h-[68px] w-[68px] drop-shadow-lg [&>svg]:h-full [&>svg]:w-full"
          aria-hidden="true"
          set:html={louiseMark}
        />
        <h1 class="mb-3 text-5xl leading-none font-black tracking-tight md:text-6xl">
          Louise CMS
        </h1>
        <p class="mx-auto mb-2 max-w-xl text-xl">
          A V8-native, inline <em class="text-primary not-italic"
            >edit-on-the-live-page</em
          > CMS for Cloudflare Workers.
        </p>
        <p class="mx-auto mb-8 max-w-lg text-base-content/60">
          No separate admin app. No JSON forms for prose. Log in, and the live
          site becomes editable in place.
        </p>
        <div class="mb-8 flex flex-wrap justify-center gap-3">
          <a
            class="btn btn-primary [&>svg]:h-5 [&>svg]:w-5"
            href="https://docs.louisecms.com"
          >
            <Fragment set:html={bookOpen} />Read the docs
          </a>
          <a
            class="btn btn-outline [&>svg]:h-5 [&>svg]:w-5"
            href="https://github.com/bowenlabs/louisecms"
          >
            <Fragment set:html={githubLogo} />GitHub
          </a>
        </div>
        <pre
          class="inline-block rounded-field border border-base-300 bg-primary/10 px-4 py-3 font-mono text-sm"><code>npm install louisecms</code></pre>
      </section>

      <section
        class="grid grid-cols-[repeat(auto-fit,minmax(16rem,1fr))] gap-4 pb-16"
        aria-label="Features"
      >
        {
          features.map((f) => (
            <article class="card rounded-box border border-base-300 bg-base-100 p-6">
              <div
                class="mb-3 text-primary [&>svg]:h-7 [&>svg]:w-7"
                aria-hidden="true"
                set:html={f.icon}
              />
              <h2 class="mb-2 text-lg font-black">{f.title}</h2>
              <p class="text-sm text-base-content/60">{f.body}</p>
            </article>
          ))
        }
      </section>

      <footer
        class="border-t border-base-300 py-10 text-center text-sm text-base-content/60"
      >
        <p>
          <a class="link link-hover text-primary" href="https://docs.louisecms.com">Documentation</a>
          · <a
            class="link link-hover text-primary"
            href="https://github.com/bowenlabs/louisecms">Source</a
          > · MIT © {year} BowenLabs
        </p>
      </footer>
    </main>
    <LouiseEditor />
  </body>
</html>
