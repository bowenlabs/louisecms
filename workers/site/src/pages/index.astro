---
// louisetoolkit.com landing page.
// Public site theme: Tailwind v4 + daisyUI, with the `louise` theme defined in
// src/styles/louise.css (auto light/dark via prefers-color-scheme). Brand type
// comes from the package (`louise/theme/fonts.css`, applied via `.louise-type`)
// and the hero mark is the real `louise-mark.svg`. Icons are Phosphor, inlined
// raw so they inherit `currentColor` — no icon font, no runtime fetch.
import { env } from "cloudflare:workers";
import { eq } from "drizzle-orm";
import { db } from "louise/db";
import "louise/theme/fonts.css";
import "../styles/louise.css";
import LouiseEditor from "../components/LouiseEditor.astro";
import Sections from "../components/Sections.astro";
import SectionsMount from "../components/SectionsMount.astro";
import { latestDraftSections } from "../lib/louise/drafts.js";
import { pages } from "../schema.js";

// SSR: the marketing app is `output: server` for Louise, and a prerendered
// `/index.html` asset would shadow the docs root on docs.louisetoolkit.com (both map
// to `/`). The homepage is now built entirely from structured "sections" (hero +
// feature grid), edited on the page and rendered by bespoke components
// (../sections/*.astro) — so the whole landing is editor-controlled while the
// design stays bespoke. Header/footer/nav remain site chrome (settings).
export const prerender = false;

const DB = (env as unknown as CloudflareEnv).DB;
const [home] = await db(DB).select().from(pages).where(eq(pages.slug, "home")).limit(1);
const editMode = Astro.locals.editMode;
// View mode renders the published main row; edit mode resumes the latest draft
// (saved via the sections dock) so work-in-progress is visible until published.
const published = (home?.sections ?? []) as Record<string, unknown>[];
const draft = editMode && home ? await latestDraftSections(DB, home.id) : null;
const sections = draft ?? published;

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Louise Toolkit — edit the live page</title>
    <meta
      name="description"
      content="A V8-native toolkit for building editable sites on Cloudflare Workers."
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body class="louise-type min-h-screen bg-base-100 text-base-content antialiased">
    <main class="mx-auto max-w-4xl px-5">
      {/* Editable hero — a structured section rendered by a bespoke component
          (../sections/Hero.astro). In edit mode the block builder mounts on this
          wrapper; in view mode it's the pixel-perfect bespoke render. */}
      <div
        data-louise-sections={editMode && home ? String(home.id) : undefined}
        data-louise-sections-initial={editMode && home ? JSON.stringify(sections) : undefined}
      >
        <Sections sections={sections} />
      </div>

      <footer
        class="border-t border-base-300 py-10 text-center text-sm text-base-content/60"
      >
        <p>
          <a class="link link-hover text-primary" href="https://docs.louisetoolkit.com">Documentation</a>
          · <a
            class="link link-hover text-primary"
            href="https://github.com/bowenlabs/louise-toolkit">Source</a
          > · MIT © {year} BowenLabs
        </p>
      </footer>
    </main>
    <SectionsMount />
    <LouiseEditor />
  </body>
</html>
