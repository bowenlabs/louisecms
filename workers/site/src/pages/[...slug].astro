---
import { env } from "cloudflare:workers";
import { LOUISE_EDGE_CACHE } from "astro:env/server";
import { eq } from "drizzle-orm";
import { db } from "louise-toolkit/db";
import { ClientRouter } from "astro:transitions";
import LouiseEditIsland from "../components/LouiseEditIsland.astro";
import SiteChrome from "../components/SiteChrome.astro";
import { publishedPageCache } from "../lib/louise/cache.js";
import { latestDraftBody, resumeReadSession } from "../lib/louise/drafts.js";
import { pagesCollection } from "../pages-collection.js";
import { pages } from "../schema.js";
import "../styles/fonts.css";
import "../styles/louise.css";

// Renders published Louise Toolkit pages (drafts are visible only in edit mode).
// The body is sanitized builder HTML, rendered straight back via set:html.
export const prerender = false;

const DB = (env as unknown as CloudflareEnv).DB;
const DRAFTS = (env as unknown as CloudflareEnv).DRAFTS;
const slug = Astro.params.slug ?? "";
const [page] = await db(DB).select().from(pages).where(eq(pages.slug, slug)).limit(1);

if (!page || (page.status !== "published" && !Astro.locals.editMode)) {
  // A 404 (or an unpublished slug seen anonymously) is left uncached — the
  // adapter defaults it to `no-store` — so a page published later isn't shadowed
  // by a cached miss (a publish only purges that page's own tag).
  return new Response("Not found", { status: 404 });
}

// Caching (#95): a published page seen by a public visitor is edge-cacheable and
// tagged for purge-on-publish — but only when LOUISE_EDGE_CACHE is on (it needs
// the CDN bypass-on-edit-cookie rule in place first; see astro.config.mjs). Edit
// mode always bypasses (set(false) → no-store) so an editor gets fresh,
// personalized HTML. The edit chrome is a deferred island (#73), so the cached
// public shell carries no editor state.
if (Astro.locals.editMode || !LOUISE_EDGE_CACHE) {
  Astro.cache.set(false);
} else {
  Astro.cache.set(publishedPageCache());
}

// View mode renders the published body; edit mode resumes the latest still-draft
// version's body so an editor sees their work-in-progress (staged via the bar's
// Save draft → /versions) until they publish, mirroring the sections workflow.
// Resume through a Sessions-API read anchored at the last auto-save's bookmark
// so the draft is read-your-writes even behind D1 read replication (#69).
let draftBody: string | null = null;
if (Astro.locals.editMode) {
  const resume = resumeReadSession(DB, Astro.cookies);
  draftBody = await latestDraftBody(resume.client, page.id, DRAFTS);
  resume.commit();
}
const body = draftBody ?? page.body;

const title = page.seoTitle || page.title;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {page.seoDescription && <meta name="description" content={page.seoDescription} />}
    {page.noindex && <meta name="robots" content="noindex" />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {/* View Transitions (#74): soft-navigate to/from the home page + other
        content pages without a full reload. */}
    <ClientRouter />
  </head>
  <body class="louise-type">
    <SiteChrome>
      <main class="louise-page">
        {
          page.status !== "published" && (
            <p class="louise-draft-note">Draft preview — not publicly visible.</p>
          )
        }
        {
          Astro.locals.editMode ? (
            <article
              class="louise-prose"
              data-louise-field={`pages:${page.id}:body`}
              data-louise-type="richtext"
              data-louise-blocks="1"
              set:html={body ?? "<p></p>"}
            />
          ) : (
            <article class="louise-prose" set:html={body ?? ""} />
          )
        }
      </main>
    </SiteChrome>
    <LouiseEditIsland server:defer versionedPageId={page.id} realtime={pagesCollection.realtime} />
  </body>
</html>
