---
import { env } from "cloudflare:workers";
import { eq } from "drizzle-orm";
import { db } from "louisecms/db";
import LouiseEditor from "../components/LouiseEditor.astro";
import SiteChrome from "../components/SiteChrome.astro";
import { latestDraftBody } from "../lib/louise/drafts.js";
import { pages } from "../schema.js";
import "louisecms/theme/fonts.css";
import "../styles/louise.css";

// Renders published Louise CMS pages (drafts are visible only in edit mode).
// The body is sanitized page-builder HTML, rendered straight back via set:html.
export const prerender = false;

const DB = (env as unknown as CloudflareEnv).DB;
const slug = Astro.params.slug ?? "";
const [page] = await db(DB).select().from(pages).where(eq(pages.slug, slug)).limit(1);

if (!page || (page.status !== "published" && !Astro.locals.editMode)) {
  return new Response("Not found", { status: 404 });
}

// View mode renders the published body; edit mode resumes the latest still-draft
// version's body so an editor sees their work-in-progress (staged via the bar's
// Save draft → /versions) until they publish, mirroring the sections workflow.
const draftBody = Astro.locals.editMode ? await latestDraftBody(DB, page.id) : null;
const body = draftBody ?? page.body;

const title = page.seoTitle || page.title;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {page.seoDescription && <meta name="description" content={page.seoDescription} />}
    {page.noindex && <meta name="robots" content="noindex" />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body class="louise-type">
    <SiteChrome>
      <main class="louise-page">
        {
          page.status !== "published" && (
            <p class="louise-draft-note">Draft preview — not publicly visible.</p>
          )
        }
        {
          Astro.locals.editMode ? (
            <article
              class="louise-prose"
              data-louise-field={`pages:${page.id}:body`}
              data-louise-type="richtext"
              data-louise-blocks="1"
              set:html={body ?? "<p></p>"}
            />
          ) : (
            <article class="louise-prose" set:html={body ?? ""} />
          )
        }
      </main>
    </SiteChrome>
    <LouiseEditor versionedPageId={page.id} />
  </body>
</html>
