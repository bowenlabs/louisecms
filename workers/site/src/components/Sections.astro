---
// Render bridge: maps each stored section item (`{ _type, ...props }`) to its
// bespoke Astro component. This is the site half of the preconfigured-blocks
// model — add a section type by adding a component here + a schema entry in
// ../sections/catalog.ts.
//
// In edit mode it also threads each section's array index (`_editIndex`) and the
// edit flag (`_editMode`) into the component, so the bespoke markup can stamp
// `data-louise-sfield` markers the client turns into in-place editors.
import { env } from "cloudflare:workers";
import { mediaMetaByUrl } from "louise-toolkit/media";
import Banner from "../sections/Banner.astro";
import CodeShowcase from "../sections/CodeShowcase.astro";
import Contact from "../sections/Contact.astro";
import CtaSection from "../sections/CtaSection.astro";
import EditDemo from "../sections/EditDemo.astro";
import FeatureGrid from "../sections/FeatureGrid.astro";
import Hero from "../sections/Hero.astro";
import Media from "../sections/Media.astro";
import Testimonial from "../sections/Testimonial.astro";

type Item = Record<string, unknown> & { _type?: string };
const { sections = [] } = Astro.props as { sections?: Item[] };
const editMode = Astro.locals.editMode;

const COMPONENTS = {
  hero: Hero,
  featureGrid: FeatureGrid,
  editDemo: EditDemo,
  codeShowcase: CodeShowcase,
  ctaSection: CtaSection,
  banner: Banner,
  testimonial: Testimonial,
  media: Media,
  contact: Contact,
} as const;

// Asset-level alt fallback (#16): on the PUBLIC render, fill a media section's
// alt from its asset's registry default when no per-usage alt is set, so an
// uploaded image is still described. Skipped in edit mode so the dock keeps
// showing the true per-usage value (empty until the editor sets it). One small
// query, and only when a media section actually needs it.
const needAltUrls = editMode
  ? []
  : sections
      .filter((s) => s._type === "media" && !s.alt && typeof s.image === "string" && s.image)
      .map((s) => s.image as string);
// Scope the lookup to just the images this page needs (bounded IN query), not
// the whole media table.
const mediaMeta = needAltUrls.length
  ? await mediaMetaByUrl(env.DB, "media", env.MEDIA_URL ?? "/media", needAltUrls)
  : null;
const withAssetAlt = (s: Item): Item => {
  if (mediaMeta && s._type === "media" && !s.alt && typeof s.image === "string") {
    const alt = mediaMeta.get(s.image)?.alt;
    if (alt) return { ...s, alt };
  }
  return s;
};
---

{
  sections.map((s, i) => {
    const r = withAssetAlt(s);
    const Comp = r._type ? COMPONENTS[r._type as keyof typeof COMPONENTS] : undefined;
    if (!Comp) return null;
    const rendered = <Comp {...r} _editIndex={i} _editMode={editMode} />;
    // Phase 1 marker contract (#182 / ADR 0005): in edit mode, wrap each section
    // in a per-section marker element so the on-canvas chrome can attach rings /
    // toolbars to the real element (via louise-toolkit/client's readSectionMarkers).
    // Public renders skip the wrapper entirely, so nothing changes off the editor.
    return editMode ? <div data-louise-section={i}>{rendered}</div> : rendered;
  })
}
