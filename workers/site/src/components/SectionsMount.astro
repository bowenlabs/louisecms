---
// Mounts the on-page block builder over the sections region in edit mode. The
// heavy Solid client is dynamically imported (only when editing) and reads the
// page id + current sections off the [data-louise-sections] wrapper, plus the
// site's field catalog. Public visitors download nothing.
---

<script>
  import type { SectionItem } from "louise-toolkit/client";

  // Teardown of the sections dock currently mounted on this <body>. A
  // view-transition nav (#74) replaces the body, so tear the old dock down —
  // removing its flush/guard listeners — before mounting the next page's dock.
  let teardown: (() => void) | null = null;

  function boot() {
    teardown?.();
    teardown = null;
    if (document.body.dataset.louiseEdit !== "1") return;
    const el = document.querySelector<HTMLElement>("[data-louise-sections]");
    if (!el?.dataset.louiseSections) return;
    const pageId = Number(el.dataset.louiseSections);
    let initial: SectionItem[] = [];
    try {
      initial = JSON.parse(el.dataset.louiseSectionsInitial || "[]");
    } catch {
      initial = [];
    }
    Promise.all([import("louise-toolkit/client"), import("../sections/catalog")]).then(
      ([client, cat]) => {
        teardown = client.mountSections(el, { catalog: cat.SECTIONS, pageId, initial });
      },
    );
  }

  // Bundled scripts run once; re-boot after every view-transition navigation so
  // the newly swapped-in sections page gets its dock (this script won't re-run).
  boot();
  document.addEventListener("astro:page-load", boot);
</script>
