---
// Mounts the Louise inline client + drawer, but only in edit mode. The inline
// script (rendered only when editMode) stamps body flags from server state; the
// bundled module script self-gates on that flag and dynamically imports the
// heavy Solid/ProseKit client, so public visitors never download it. Drop
// <LouiseEditor /> just before </body> on any page that should be editable.
const { editMode, editor } = Astro.locals;
// A versioned page (its inline body edits stage drafts + publish, like the
// sections/home surface). Pages that own their own versioned surface (the
// sections dock) leave this undefined so the bar doesn't add a second Publish.
const { versionedPageId } = Astro.props as { versionedPageId?: number };
---

{
  editMode && (
    <script
      is:inline
      define:vars={{ userName: editor?.name ?? "Editor", versionedPageId: versionedPageId ?? null }}
    >
      document.body.dataset.louiseEdit = "1";
      document.body.dataset.louiseUser = userName;
      if (versionedPageId != null) document.body.dataset.louiseVersionedPage = String(versionedPageId);
    </script>
  )
}
<script>
  if (document.body.dataset.louiseEdit === "1") {
    Promise.all([import("louisecms/client"), import("louisecms/client/drawer")]).then(
      ([client, drawer]) => {
        drawer.mountDrawer({ userName: document.body.dataset.louiseUser || "Editor" });
        const versioned = document.body.dataset.louiseVersionedPage;
        client.mountLouise({
          onOpenDrawer: () => window.dispatchEvent(new Event(drawer.OPEN_DRAWER_EVENT)),
          versionedPageId: versioned ? Number(versioned) : undefined,
        });
      },
    );
  }
</script>
