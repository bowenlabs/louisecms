---
// The Louise edit-mode chrome as a deferred Server Island (#73). Rendered at the
// use site with `server:defer` so the public page shell stays cookie-independent
// and edge-cacheable (#95): an anonymous visitor gets an EMPTY island (nothing
// below renders, so no editor script is ever in the cached HTML), while an
// editor's request resolves the client bootstrap on demand — the island runs its
// own request through the middleware, so `Astro.locals.editMode` is re-derived
// from the edit cookie here.
//
// Both scripts are gated on edit mode: the inline script stamps body flags from
// server state; the bundled module self-gates on that flag and dynamically
// imports the heavy Solid/ProseKit client, so it is only ever fetched by editors.
// Drop `<LouiseEditIsland server:defer versionedPageId={…} />` before </body> on
// any page that should be editable.
const { editMode, editor } = Astro.locals;
// A versioned page (its inline body edits stage drafts + publish). Pages that own
// their own versioned surface (the sections dock) leave this undefined so the bar
// doesn't add a second Publish.
const { versionedPageId } = Astro.props as { versionedPageId?: number };
---

{
  editMode && (
    <>
      <script
        is:inline
        data-astro-rerun
        define:vars={{
          userName: editor?.name ?? "Editor",
          versionedPageId: versionedPageId ?? null,
        }}
      >
        // `data-astro-rerun` so a view-transition nav (#74) re-stamps the freshly
        // swapped-in <body> with this page's edit flags before the bootstrap re-mounts.
        document.body.dataset.louiseEdit = "1";
        document.body.dataset.louiseUser = userName;
        if (versionedPageId != null)
          document.body.dataset.louiseVersionedPage = String(versionedPageId);
        else delete document.body.dataset.louiseVersionedPage;
      </script>
      <script>
        import { actions } from "astro:actions";

        // Mount (or re-mount) the editor from the current <body> flags. Re-reads
        // per-page config (versionedPageId) each call, so a view-transition nav to
        // another page mounts against that page — not a stale first-load closure.
        // mountLouise/mountSettings are idempotent per page (guards cleared on
        // astro:after-swap), so a redundant call is a no-op.
        function boot() {
          if (document.body.dataset.louiseEdit !== "1") return;
          Promise.all([import("louise-toolkit/client"), import("louise-toolkit/client/settings")])
            .then(([client, settings]) => {
              settings.mountSettings({ userName: document.body.dataset.louiseUser || "Editor" });
              const versioned = document.body.dataset.louiseVersionedPage;
              client.mountLouise({
                onOpenSettings: () => window.dispatchEvent(new Event(settings.OPEN_SETTINGS_EVENT)),
                versionedPageId: versioned ? Number(versioned) : undefined,
                // Route the normal debounced auto-save through the typed Astro
                // Actions (#138). The client keeps its raw keepalive fetch for the
                // page-hide / unload / before-swap flush only (an Action can't
                // keepalive). Each callable resolves on success and rejects on failure.
                actions: {
                  save: async (input) => {
                    const { data, error } = await actions.louise.save(input);
                    if (error) throw error;
                    return data;
                  },
                  saveDraft: async (input) => {
                    const { data, error } = await actions.louise.saveDraft(input);
                    if (error) throw error;
                    return data;
                  },
                },
              });
            })
            // Without this, a throw while booting the editor is a silent unhandled
            // rejection — surface it so the next init failure is visible.
            .catch((err) => console.error("[louise] editor bootstrap failed", err));
        }

        // Bundled scripts run once and a server:defer island may inject this after
        // the initial astro:page-load has fired — so boot now for the first page…
        boot();
        // …and after every view-transition navigation (#74): <body> (bar, fields,
        // drawer) was replaced and this script won't re-run, so re-boot for the
        // page just swapped in.
        document.addEventListener("astro:page-load", boot);
      </script>
    </>
  )
}
