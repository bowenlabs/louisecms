---
// Real-user Core Web Vitals beacon (#106). A tiny, cookieless inline script that
// reports LCP / CLS / INP to /api/louise/vitals on the first page-hide, where
// vitalsRoute writes them to the ANALYTICS (Analytics Engine) dataset. Skipped in
// edit mode so an editor's own (heavier, edit-chrome-laden) sessions don't skew
// the owner's field data.
import { cwvBeaconScript } from "louise-toolkit/analytics";

const beacon = cwvBeaconScript();
const { editMode } = Astro.locals;
---

{!editMode && <script is:inline set:html={beacon} />}
