---
// Bespoke hero section — the SITE owns this design (Tailwind + daisyUI, the real
// brand look). It renders from structured section props; editors never touch its
// markup or classes, only its fields (heading/tagline/cta). This is how a
// preconfigured block keeps a pixel-perfect bespoke design while staying
// editor-controlled.
//
// In edit mode it stamps `data-louise-sfield` markers on the visible text nodes
// so the client can make them editable in place, and always renders those nodes
// (even when empty) so there's something to click into. `ctaHref` has no visible
// text, so it's edited in the dock, not here.
import louiseMark from "../assets/louise-mark.svg?raw";

interface Props {
  heading?: string;
  tagline?: string;
  ctaLabel?: string;
  ctaHref?: string;
  /** Optional uploaded logo (media URL). Falls back to the built-in Louise mark. */
  logo?: string;
  _editIndex?: number;
  _editMode?: boolean;
}
const {
  heading = "",
  tagline = "",
  ctaLabel = "",
  ctaHref = "",
  logo = "",
  _editIndex = 0,
  _editMode: edit = false,
} = Astro.props;
const idx = _editIndex;
---

<section class="louise-type px-5 pt-24 pb-12 text-center">
  {
    logo ? (
      <img
        src={logo}
        alt=""
        class="mx-auto mb-6 h-[68px] w-[68px] object-contain drop-shadow-lg"
      />
    ) : (
      <div
        class="mx-auto mb-6 h-[68px] w-[68px] drop-shadow-lg [&>svg]:h-full [&>svg]:w-full"
        aria-hidden="true"
        set:html={louiseMark}
      />
    )
  }
  <h1
    class="mb-3 text-5xl leading-none font-black tracking-tight md:text-6xl"
    data-louise-sfield={edit ? `${idx}.heading` : undefined}
  >
    {heading || (edit ? "" : "Louise Toolkit")}
  </h1>
  {
    (edit || tagline) && (
      <p
        class="mx-auto mb-8 max-w-xl text-xl text-base-content/70"
        data-louise-sfield={edit ? `${idx}.tagline` : undefined}
        data-louise-multiline={edit || undefined}
      >
        {tagline}
      </p>
    )
  }
  {
    (edit || (ctaLabel && ctaHref)) && (
      <a
        class="btn btn-primary"
        href={ctaHref || "#"}
        data-louise-sfield={edit ? `${idx}.ctaLabel` : undefined}
      >
        {ctaLabel}
      </a>
    )
  }
</section>
