---
// Bespoke hero — the SITE owns this design (Tailwind + daisyUI `louise-dark`
// tokens, the real brand look). It renders from section props; editors never
// touch its markup or classes, only its fields (badge/heading/tagline) and the
// action-row blocks. The animated edge-network globe and the primitives marquee
// are baked-in chrome, not editable content.
//
// Action row = a first-class `blocks` layer (#182 / ADR 0005): an ordered, mixed
// list of `cta` (button) / `install` (copy-command chip) blocks, each on-canvas
// (blue ring/toolbar) and reorderable in place — the reference slice proving a
// *heterogeneous* block catalog (vs featureGrid's homogeneous cards). A legacy
// hero (flat ctaLabel/ctaHref/installCommand) still renders via a fallback while
// the shared DB is re-seeded.
//
// In edit mode it stamps `data-louise-sfield` on the visible text nodes so the
// client can make them editable in place, and always renders those nodes (even
// when empty) so there's something to click into. `ctaHref` and the install
// command have no clean visible node, so they're edited in the block's dock
// fields (non-inline).
import Icon from "../components/Icon.astro";
import { lightningFillSvg } from "../lib/landing-icons.js";

// One action-row item — a `cta` (button) or `install` (copy-command chip) block.
interface ActionBlock {
  _type?: string;
  label?: string;
  href?: string;
  command?: string;
}
interface Props {
  badge?: string;
  heading?: string;
  headingAccent?: string;
  tagline?: string;
  blocks?: ActionBlock[];
  // Legacy direct fields — accepted while the shared DB still carries the
  // pre-block hero (expand/contract seed); `blocks` wins when present.
  ctaLabel?: string;
  ctaHref?: string;
  installCommand?: string;
  _editIndex?: number;
  _editMode?: boolean;
}
const {
  badge = "",
  heading = "",
  headingAccent = "",
  tagline = "",
  blocks,
  ctaLabel = "",
  ctaHref = "",
  installCommand = "pnpm add louise-toolkit",
  _editIndex = 0,
  _editMode: edit = false,
} = Astro.props;
const idx = _editIndex;

const DEFAULT_INSTALL = "pnpm add louise-toolkit";
// `blocks` is the first-class action layer (#182); fall back to the legacy direct
// fields (one CTA + one install chip) while an un-migrated hero row still carries
// them. Block markers are stamped only for the block path.
const useBlocks = Array.isArray(blocks) && blocks.length > 0;
const actions: ActionBlock[] = useBlocks
  ? (blocks as ActionBlock[])
  : [
      { _type: "cta", label: ctaLabel, href: ctaHref },
      { _type: "install", command: installCommand },
    ];
// A CTA label is edited in place; its path is the block path (blocks) or the
// equivalent legacy field (a legacy hero has exactly one CTA).
const ctaLabelPath = (j: number) => (useBlocks ? `${idx}.blocks.${j}.label` : `${idx}.ctaLabel`);
const blockAttr = (j: number) => (edit && useBlocks ? `${idx}.blocks.${j}` : undefined);

// Marquee tokens — the eight primitives, colored on a 4-step brand cycle
// (blue → orange → green → gold). Rendered twice so the -50% loop is seamless.
const PRIMITIVES = ["content", "db", "media", "forms", "commerce", "email", "queues", "auth"];
const MARQUEE_COLORS = ["text-primary", "text-error", "text-success", "text-warning"];
const marquee = [...PRIMITIVES, ...PRIMITIVES];
---

<section
  class="lt-landing relative px-[clamp(20px,4vw,48px)] pt-[clamp(36px,6vw,60px)] pb-10 text-center"
>
  {/* Animated edge-network globe (three.js), decorative. */}
  <div
    aria-hidden="true"
    class="pointer-events-none absolute top-[46%] left-1/2 h-[min(760px,96vw)] w-[min(760px,96vw)] -translate-x-1/2 -translate-y-1/2 opacity-55"
  >
    <canvas data-lt-globe class="block h-full w-full"></canvas>
  </div>

  <div class="relative mx-auto max-w-[1100px]">
    <div
      class="mb-[34px] inline-flex items-center gap-2 rounded-full border-[1.5px] border-primary px-4 py-1.5 text-[13px] font-bold tracking-[0.1em] text-[#6cb2ff]"
    >
      <Icon svg={lightningFillSvg} class="text-[15px] text-accent" />
      <span data-louise-sfield={edit ? `${idx}.badge` : undefined}>
        {badge || (edit ? "" : "V8-NATIVE · RUNS ON CLOUDFLARE WORKERS")}
      </span>
    </div>

    <h1
      class="lt-display lt-stretch-140 mb-[30px] text-[clamp(44px,8.5vw,104px)] leading-[.94] tracking-[-0.02em]"
    >
      <span data-louise-sfield={edit ? `${idx}.heading` : undefined}>
        {heading || (edit ? "" : "Stop building")}
      </span><br />
      <span class="text-[#2f92f5]" data-louise-sfield={edit ? `${idx}.headingAccent` : undefined}>
        {headingAccent || (edit ? "" : "admin panels.")}
      </span>
    </h1>

    {/* Rich-text field (#182): a <div> (not <p>) so the inline ProseKit editor can
        mount into it; the stored value is sanitized HTML rendered via set:html. */}
    <div
      class="louise-rt-field mx-auto mb-10 max-w-[30em] text-[clamp(17px,2.2vw,21px)] leading-[1.6] text-pretty text-[#aab3c2]"
      data-louise-sfield={edit ? `${idx}.tagline` : undefined}
      data-louise-type={edit ? "richtext" : undefined}
      set:html={tagline ||
        (edit
          ? ""
          : "Log in. Click the text. Type. Louise makes the live site the editor — no admin app, no JSON forms for prose, ever.")}
    />

    <div class="flex flex-wrap items-center justify-center gap-[14px]">
      {
        actions.map((a, j) =>
          a._type === "install" ? (
            <button
              type="button"
              data-louise-block={blockAttr(j)}
              data-lt-copy
              data-lt-copy-text={a.command || DEFAULT_INSTALL}
              aria-label={`Copy install command: ${a.command || DEFAULT_INSTALL}`}
              class="inline-flex cursor-pointer items-center gap-3 rounded-full border-[1.5px] border-neutral bg-white/[0.06] px-[22px] py-[15px] font-mono text-[15px] text-base-content transition hover:border-accent"
            >
              <span class="font-bold text-success">$</span>
              <span data-lt-copy-cmd>{a.command || DEFAULT_INSTALL}</span>
              <span data-lt-copy-label aria-live="polite" class="text-[12px] font-bold text-accent">
                Copy
              </span>
            </button>
          ) : (
            <a
              data-louise-block={blockAttr(j)}
              class="inline-block rounded-full bg-primary px-[34px] py-4 text-[17px] font-extrabold text-primary-content transition hover:-translate-y-0.5 hover:bg-[#2f92f5]"
              href={a.href || "https://docs.louisetoolkit.com/guide/getting-started"}
              data-louise-sfield={edit ? ctaLabelPath(j) : undefined}
            >
              {a.label || (edit ? "" : "Get started")}
            </a>
          ),
        )
      }
    </div>
  </div>
</section>

{/* Primitives marquee — decorative, baked chrome. */}
<div
  aria-hidden="true"
  class="mt-14 overflow-hidden border-y-[1.5px] border-neutral py-4 whitespace-nowrap"
>
  <div class="lt-marquee-track gap-0">
    {
      marquee.map((name, i) => (
        <span
          class:list={[
            "lt-stretch-130 inline-flex items-center gap-[22px] px-[22px] text-[20px] font-black tracking-[0.04em] uppercase",
            MARQUEE_COLORS[i % 4],
          ]}
        >
          {name}
          <Icon svg={lightningFillSvg} class="text-[16px] text-neutral" />
        </span>
      ))
    }
  </div>
</div>

<script>
  import { initEdgeGlobe } from "../lib/edge-globe.js";

  // Install-command copy button(s).
  function wireCopy() {
    document.querySelectorAll<HTMLButtonElement>("[data-lt-copy]").forEach((btn) => {
      if (btn.dataset.ltCopyWired) return;
      btn.dataset.ltCopyWired = "1";
      const label = btn.querySelector<HTMLElement>("[data-lt-copy-label]");
      btn.addEventListener("click", async () => {
        const cmd =
          btn.querySelector<HTMLElement>("[data-lt-copy-cmd]")?.textContent?.trim() ||
          btn.dataset.ltCopyText ||
          "";
        try {
          await navigator.clipboard.writeText(cmd);
        } catch {
          /* clipboard blocked — nothing to do */
        }
        if (label) {
          label.textContent = "Copied!";
          window.setTimeout(() => (label.textContent = "Copy"), 1600);
        }
      });
    });
  }

  function boot() {
    wireCopy();
    const canvas = document.querySelector<HTMLCanvasElement>("[data-lt-globe]");
    if (canvas) {
      try {
        initEdgeGlobe(canvas, {
          nodeColor: "#f3ae29",
          arcColor: "#db6327",
          wireColor: "#1481ef",
          wireOpacity: 0.22,
          nodeOpacity: 0.9,
          density: 800,
          arcCount: 32,
          speed: 1,
        });
      } catch {
        /* WebGL unavailable — hero reads fine without the globe */
      }
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", boot, { once: true });
  } else {
    boot();
  }
</script>
