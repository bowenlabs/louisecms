# Local dev config for `astro dev` — astro:env reads these from .env (copy to .env).
# In production these come from wrangler instead: `vars` in wrangler.jsonc for the
# public ones, and `wrangler secret put SQUARE_TOKEN` for the secret.
SQUARE_ENV=sandbox
SQUARE_APP_ID=
SQUARE_LOCATION=
SQUARE_TOKEN=
FROM_EMAIL=sandbox@louisetoolkit.com
